PROJECT_NAME=Legal Case System
VERSION=0.1.0
API_V1_STR=/api/v1

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=legal_case

SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
WECHAT_MINIAPP_APP_ID=
WECHAT_MINIAPP_APP_SECRET=
WECHAT_MINIAPP_MOCK_LOGIN=true
WECHAT_MINIAPP_CLIENT_ENTRY_PAGE=pages/login/index
FILE_ACCESS_TOKEN_EXPIRE_MINUTES=10
FILE_UPLOAD_MAX_SIZE_BYTES=52428800
FILE_UPLOAD_ALLOWED_EXTENSIONS=[".pdf", ".doc", ".docx", ".jpg", ".jpeg", ".png", ".xls", ".xlsx", ".txt"]
FILE_UPLOAD_ALLOWED_MIME_TYPES=["application/pdf", "application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/vnd.ms-excel", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "image/jpeg", "image/jpg", "image/png", "text/plain"]

LOCAL_STORAGE_DIR=storage
STORAGE_BACKEND=local
STORAGE_DIRECT_UPLOAD_ENABLED=false
STORAGE_DELETE_POLICY=immediate
STORAGE_RETENTION_PREFIX=_retained
STORAGE_PENDING_PREFIX=_pending
STORAGE_PUBLIC_BASE_URL=

TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=

ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_REGION=

AI_ENABLED=true
AI_MOCK_MODE=true
OPENAI_API_KEY=
# 兼容字段：优先读取 OPENAI_BASE_URL，未设置时回退到 OPENAI_API_BASE
OPENAI_BASE_URL=
OPENAI_API_BASE=https://api.openai.com/v1
# 兼容字段：优先读取 AI_MODEL，未设置时回退到 OPENAI_MODEL
AI_MODEL=
OPENAI_MODEL=gpt-5.4
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_SECONDS=60
AI_TOKEN_COST_PER_1K=0.03
AI_DAILY_TOKEN_LIMIT=100000

# Queue driver: db (MVP default) | cmq (future extension)
QUEUE_DRIVER=db
AI_DB_QUEUE_EAGER=true
AI_DB_QUEUE_POLL_SECONDS=2
AI_DB_QUEUE_MAX_RETRIES=3
AI_DB_QUEUE_RETRY_BACKOFF_SECONDS=30
AI_DB_QUEUE_STALE_TASK_SECONDS=900
AI_DB_QUEUE_HEARTBEAT_FILE=/tmp/legal-ai-worker-heartbeat.json
AI_DB_QUEUE_HEALTHCHECK_MAX_AGE_SECONDS=90
AI_DB_QUEUE_WORKER_ID=
TENCENT_QUEUE_REGION=
TENCENT_QUEUE_NAMESPACE=
TENCENT_QUEUE_TOPIC_NAME=
TENCENT_QUEUE_SUBSCRIPTION_NAME=
TENCENT_QUEUE_ENDPOINT=
TENCENT_QUEUE_SECRET_ID=
TENCENT_QUEUE_SECRET_KEY=

# Budget controls (leave empty to disable)
AI_MONTHLY_BUDGET_LIMIT=
AI_CASE_BUDGET_LIMIT=
AI_BUDGET_DEGRADE_MODEL=

# Node + Puppeteer report service
REPORT_SERVICE_BASE_URL=http://report-service:3001
REPORT_SERVICE_TIMEOUT_SECONDS=30
